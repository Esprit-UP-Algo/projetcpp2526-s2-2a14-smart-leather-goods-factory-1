  <property name="styleSheet">
   <string notr="true">
/* =====================================================
   PREMIUM LEATHER THEME - MASTER CRAFTSMAN EDITION
===================================================== */

/* Global Background - Distressed Leather */
QDialog {
    background-color: #2c1a0e;
    background-image: url(:/images/leather-texture.png);
    background-repeat: repeat;
}

/* Main Container - Embossed Leather Panel */
#mainContainer {
    background-color: rgba(235, 215, 190, 0.95);
    border: 3px solid #8b5a2b;
    border-radius: 30px;
    border-bottom: 5px solid #6b3e1a;
}

/* Logo/Title Area - Tooled Leather */
#titleFrame {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #c49a6c,
        stop:0.5 #a67c52,
        stop:1 #8b5a2b);
    border: 2px solid #e9d4b0;
    border-radius: 20px;
    padding: 15px;
}

#titleFrame QLabel {
    color: #f5e6d3;
    font-size: 28px;
    font-weight: bold;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
}

/* Login Form Container - Hand-Stitched Leather */
#loginForm {
    background-color: #f8efe4;
    border: 3px solid #b2825b;
    border-radius: 25px;
    border-left: 6px solid #8b5a2b;
    border-bottom: 6px solid #6b3e1a;
}

/* Form Title */
#formTitle {
    color: #5d3a1b;
    font-size: 24px;
    font-weight: bold;
    font-family: &quot;Segoe UI&quot;, &quot;Times New Roman&quot;, serif;
    padding: 10px 0;
    border-bottom: 2px dashed #b2825b;
}

/* Input Fields - Burnished Leather */
QLineEdit {
    background-color: #fff9f0;
    border: 2px solid #b2825b;
    border-radius: 12px;
    padding: 12px 15px;
    font-size: 14px;
    color: #3d2b1a;
    selection-background-color: #c49a6c;
    margin: 5px 0;
}

QLineEdit:focus {
    border: 3px solid #8b5a2b;
    background-color: #ffffff;
    border-left: 8px solid #c49a6c;
}

QLineEdit::placeholder {
    color: #9b7a5c;
    font-style: italic;
}

/* Password Toggle Button - Metal Rivet Style */
#btnTogglePassword {
    background-color: #d4b28c;
    border: 2px solid #6b3e1a;
    border-radius: 12px;
    color: #3d2b1a;
    font-weight: bold;
    padding: 8px 15px;
    border-bottom: 4px solid #4a2a12;
}

#btnTogglePassword:hover {
    background-color: #e4c4a4;
    border-bottom: 2px solid #4a2a12;
}

/* Checkbox - Leather Toggle Style */
QCheckBox {
    color: #3d2b1a;
    font-weight: bold;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    background-color: #fff9f0;
    border: 2px solid #b2825b;
    border-radius: 5px;
}

QCheckBox::indicator:checked {
    background-color: #8b5a2b;
    border: 2px solid #5d3a1b;
}

/* Links - Tooled Leather Style */
.linkLabel {
    color: #6b3e1a;
    font-size: 13px;
    font-weight: bold;
    text-decoration: underline;
    padding: 8px;
    background-color: rgba(255, 255, 255, 0.3);
    border-radius: 8px;
}

.linkLabel:hover {
    color: #c49a6c;
    background-color: rgba(180, 130, 90, 0.2);
}

/* Action Buttons - Hand-Stitched Leather Patches */
QPushButton {
    border: 3px solid #5d3a1b;
    border-radius: 15px;
    font-size: 16px;
    font-weight: bold;
    padding: 12px 25px;
    min-width: 150px;
}

#btnSignup {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #a67c52,
        stop:1 #7b4f2a);
    color: #f5e6d3;
    border-bottom: 6px solid #4a2a12;
}

#btnSignup:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #b88e64,
        stop:1 #8b5a2b);
    border-bottom: 4px solid #4a2a12;
}

#btnLogin {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #6f8f3d,
        stop:1 #4c6328);
    color: #f5e6d3;
    border-bottom: 6px solid #2c3d18;
}

#btnLogin:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #8ab048,
        stop:1 #5f7a32);
    border-bottom: 4px solid #2c3d18;
}

/* Decorative Elements - Leather Stitching */
.stitching {
    background-color: transparent;
    border: 2px dashed #b2825b;
    border-radius: 30px;
}

/* Help Section */
#helpSection {
    background-color: rgba(180, 130, 90, 0.2);
    border-top: 2px solid #b2825b;
    border-radius: 0 0 25px 25px;
    padding: 15px;
}
   </string>
