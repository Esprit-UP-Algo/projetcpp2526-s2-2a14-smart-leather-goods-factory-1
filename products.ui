     <property name="styleSheet">
      <string notr="true">/* =======================
   TABLE – PERFECT ROUNDED LEATHER
======================= */

QTableView {
    background-color: #fffaf5;
    border: 2px solid #b08a6b;
    border-radius: 14px;
    gridline-color: #e0d2c5;
    padding: 0px;
}

/* IMPORTANT: clip the viewport */
QTableView::viewport {
    background-color: #fffaf5;
    border-radius: 12px;
}

/* Remove internal borders */
QTableView QTableCornerButton::section {
    background-color: #6b3e26;
    border: none;
}

/* Header styling */
QHeaderView {
    background-color: transparent;
}

QHeaderView::section {
    background-color: qlineargradient(
        x1:0, y1:0, x2:0, y2:1,
        stop:0 #6b3e26,
        stop:1 #4a2717
    );
    color: #fffaf5;
    padding: 8px;
    border: none;
    font-weight: bold;
}

/* Round TOP corners manually */
QHeaderView::section:first {
    border-top-left-radius: 12px;
}

QHeaderView::section:last {
    border-top-right-radius: 12px;
}

/* Table items */
QTableView::item {
    padding: 8px;
    border-bottom: 1px solid #e0d2c5;
}

/* Selection */
QTableView::item:selected {
    background-color: #d8b59c;
    color: #2a1a12;
}
</string>
