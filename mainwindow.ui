  <property name="styleSheet">
   <string notr="true">/* ============================= */
/* ===== BACKGROUND FIX ===== */
/* ============================= */
QWidget#centralwidget {
    background-color: #f4efe9;
}

QWidget {
    background-color: transparent;
}

/* ============================= */
/* ===== GLOBAL ===== */
/* ============================= */
QMainWindow {
    background-color: #f4efe9;
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
}

/* ============================= */
/* ===== GROUP BOX ===== */
/* ============================= */
QGroupBox {
    background-color: #f8f3ed;
    border: 1px solid #c7b299;
    border-radius: 8px;
    margin-top: 22px;
    padding: 12px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 14px;
    padding: 0 8px;
    color: #4b2e1f;
    font-weight: bold;
}

/* ============================= */
/* ===== LABELS ===== */
/* ============================= */
QLabel {
    color: #3b2a1a;
    font-weight: 500;
}

/* ============================= */
/* ===== INPUTS (LISIBLES) ===== */
/* ============================= */
QLineEdit,
QTextEdit,
QComboBox,
QDateEdit {
    background-color: #ffffff;
    color: #2b1a0f;
    border: 2px solid #b89b82;
    border-radius: 6px;
    padding: 6px;
    font-size: 11pt;
    min-height: 26px;
}

/* Placeholder */
QLineEdit::placeholder {
    color: #9a7f66;
    font-style: italic;
}

/* Focus */
QLineEdit:focus,
QTextEdit:focus,
QComboBox:focus,
QDateEdit:focus {
    border: 2px solid #6b3f2b;
    background-color: #fffdfb;
}

/* Désactivé */
QLineEdit:disabled,
QComboBox:disabled,
QDateEdit:disabled {
    background-color: #eee6dd;
    color: #7a6a5a;
}

/* ============================= */
/* ===== COMBOBOX ===== */
/* ============================= */
QComboBox::drop-down {
    border-left: 1px solid #b89b82;
    width: 22px;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    color: #2b1a0f;
    selection-background-color: #d8c2aa;
    selection-color: black;
}

/* ============================= */
/* ===== TABLE ===== */
/* ============================= */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #c7b299;
    gridline-color: #e0d6c9;
}

QHeaderView::section {
    background-color: #6b3f2b;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

QTableWidget::item:selected {
    background-color: #d8c2aa;
    color: black;
}

/* ============================= */
/* ===== BUTTONS ===== */
/* ============================= */
QPushButton {
    background-color: #6b3f2b;
    color: white;
    border-radius: 6px;
    padding: 7px 16px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #8a5a44;
}

/* ============================= */
/* ===== ACTION BUTTONS ===== */
/* ============================= */
QPushButton#pushButton_3 { /* Ajouter */
    background-color: #5a7d3b;
}

QPushButton#pushButton_4 { /* Modifier */
    background-color: #d07a2d;
}

QPushButton#pushButton_5 { /* Supprimer */
    background-color: #b23a2b;
}

QPushButton#pushButton_6 { /* Actualiser */
    background-color: #7b4a32;
}

/* ============================= */
/* ===== MENU BAR ===== */
/* ============================= */
QMenuBar {
    background-color: #6b3f2b;
    color: white;
}

QMenuBar::item:selected {
    background-color: #8a5a44;
}

/* ============================= */
/* ===== STATUS BAR ===== */
/* ============================= */
QStatusBar {
    background-color: #e7dccf;
}
/* ============================= */
/* ===== POPUP / DIALOG FIX ===== */
/* ============================= */
QDialog {
    background-color: #f8f3ed;
}
/* ============================= */
/* ===== TABLE CONTENT FIX ===== */
/* ============================= */
QTableWidget {
    background-color: #ffffff;
    color: #2b1a0f;                 /* TEXTE VISIBLE */
    border: 1px solid #c7b299;
    gridline-color: #e0d6c9;
}

/* Cellules */
QTableWidget::item {
    color: #2b1a0f;                 /* TEXTE des cellules */
    background-color: #ffffff;
}

/* Cellule sélectionnée */
QTableWidget::item:selected {
    background-color: #d8c2aa;
    color: #2b1a0f;
}

/* Ligne sélectionnée mais pas active */
QTableWidget::item:selected:!active {
    background-color: #e6d2bd;
    color: #2b1a0f;
}

</string>
