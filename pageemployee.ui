    <property name="styleSheet">
     <string notr="true">/* ===== GLOBAL ===== */
QMainWindow {
    background-color: #f4efe9;
    font-family: &quot;Segoe UI&quot;;
    font-size: 11pt;
}

/* ===== GROUP BOX ===== */
QGroupBox {
    background-color: #f8f3ed;
    border: 1px solid #c7b299;
    border-radius: 6px;
    margin-top: 20px;
    padding: 10px;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 6px;
    color: #4b2e1f;
    font-weight: bold;
}

/* ===== LABELS ===== */
QLabel {
    color: #3b2a1a;
}

/* ===== INPUTS ===== */
QLineEdit, QTextBrowser, QComboBox, QDateEdit {
    background-color: #ffffff;
    border: 1px solid #c7b299;
    border-radius: 4px;
    padding: 4px;
}

QComboBox::drop-down {
    border-left: 1px solid #c7b299;
}

/* ===== TABLE ===== */
QTableWidget {
    background-color: #ffffff;
    border: 1px solid #c7b299;
    gridline-color: #e0d6c9;
}

QHeaderView::section {
    background-color: #6b3f2b;
    color: white;
    padding: 6px;
    border: none;
    font-weight: bold;
}

QTableWidget::item:selected {
    background-color: #d8c2aa;
    color: black;
}

/* ===== BUTTONS (DEFAULT) ===== */
QPushButton {
    background-color: #6b3f2b;
    color: white;
    border-radius: 6px;
    padding: 6px 14px;
}

QPushButton:hover {
    background-color: #8a5a44;
}

/* ===== ACTION BUTTONS ===== */
QPushButton#pushButton_3 { /* Ajouter */
    background-color: #5a7d3b;
}

QPushButton#pushButton_4 { /* Modifier */
    background-color: #d07a2d;
}

QPushButton#pushButton_5 { /* Supprimer */
    background-color: #b23a2b;
}

QPushButton#pushButton_6 { /* Actualiser */
    background-color: #7b4a32;
}

/* ===== MENU BAR ===== */
QMenuBar {
    background-color: #6b3f2b;
    color: white;
}

QMenuBar::item:selected {
    background-color: #8a5a44;
}

/* ===== STATUS BAR ===== */
QStatusBar {
    background-color: #e7dccf;
}
</string>
